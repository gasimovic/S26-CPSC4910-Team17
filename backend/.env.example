# --- Auth ---
JWT_SECRET=RE1GAvIBoEu20JPt6rEMvwQeEiBMG/gRBzo7jDA1OGo=

# --- Cookies ---
COOKIE_NAME=gdip_token
COOKIE_SECURE=false

# --- eBay Production API ---
