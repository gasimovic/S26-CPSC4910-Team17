# --- MySQL (AWS RDS) ---
# Use either the individual DB_* variables OR DATABASE_URL (both included for convenience)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=TeamNN
DB_PASSWORD=change-me
DB_NAME=TeamNN_DB

# Optional single-URL form
DATABASE_URL=mysql://TeamNN:change-me@your-rds-endpoint.rds.amazonaws.com:3306/TeamNN_DB

# --- Auth ---
JWT_SECRET=RE1GAvIBoEu20JPt6rEMvwQeEiBMG/gRBzo7jDA1OGo=

# --- Cookies ---
COOKIE_NAME=gdip_token
COOKIE_SECURE=false

# --- eBay API ---
# Sandbox keys (limited/no real data — for testing auth flow only)
EBAY_CLIENT_ID=your-sandbox-app-id
EBAY_CLIENT_SECRET=your-sandbox-cert-id

# Production keys (optional — gives real item listings)
# Get these from developer.ebay.com → Application Keys → "Get a Production Keyset"
# If set, the app will automatically use the production API with real eBay data.
# EBAY_PROD_CLIENT_ID=your-production-app-id
# EBAY_PROD_CLIENT_SECRET=your-production-cert-id

# Required to activate Production keys (eBay GDPR marketplace account-deletion compliance)
# Set EBAY_VERIFICATION_TOKEN to the token you entered on the eBay developer portal under
# Application Keys → Alerts & Notifications → Marketplace Account Deletion.
# Set EBAY_DELETION_ENDPOINT to the full public HTTPS URL of your endpoint.
# EBAY_VERIFICATION_TOKEN=your-verification-token-from-ebay-portal
# EBAY_DELETION_ENDPOINT=https://yourapp.com/api/sponsor/ebay/account-deletion